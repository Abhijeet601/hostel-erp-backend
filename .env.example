# Local development: use Railway public MySQL proxy from your MySQL service variables.
DATABASE_URL=mysql+pymysql://root:YOUR_PASSWORD@reseau.proxy.rlwy.net:35994/railway
MYSQL_PUBLIC_URL=mysql://root:YOUR_PASSWORD@reseau.proxy.rlwy.net:35994/railway

# Railway backend service (set automatically when MySQL is linked):
# MYSQL_URL=mysql://root:YOUR_PASSWORD@mysql.railway.internal:3306/railway
# RAILWAY_PUBLIC_DOMAIN=hostel-erp-backend-production.up.railway.app
# PUBLIC_BASE_URL=https://hostel-erp-backend-production.up.railway.app

APP_NAME=MMC Hostel ERP API
APP_DEBUG=true
ALLOWED_ORIGINS=null,http://localhost:3000,http://127.0.0.1:3000,http://localhost:5500,http://127.0.0.1:5500,http://localhost:8000,http://127.0.0.1:8000,https://magadhmahilacollege.org,https://www.magadhmahilacollege.org,https://hostel-erp-backend-production.up.railway.app
ALLOWED_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$|^https://.*\.up\.railway\.app$|^https://(www\.)?magadhmahilacollege\.org$

# Generated Hostel ERP files.
# Point this to your mounted Cloudflare/cloudflared storage folder if available.
HOSTEL_ERP_DATA_DIR=mmc-uploads/hostel erp data
HOSTEL_ERP_RECEIPT_DIR=mmc-uploads/hostel erp data/receipts

# Cloudflare R2 Storage — S3-compatible object storage for PDFs, images, etc.
# Get credentials from Cloudflare Dashboard > R2 > Manage R2 API Tokens
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=mmc-erp-files
R2_PUBLIC_URL=https://your-bucket.r2.dev
